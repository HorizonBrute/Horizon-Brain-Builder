# GitHub access — CONFIG the delivery pipeline consumes (non-secret).
# ===========================================================================
# This is the knob surface for how the neuron's git delivery adapter reaches
# GitHub. It is env_file'd into the delivery run (and the neuron service), so
# every value here lands in the process environment the adapter reads.
#
# THE INVARIANT (non-negotiable, see README.md):
#   NO credential material lives here or anywhere under the brain. This file
#   holds only NON-SECRET configuration — which protocol, which auth MODE, and
#   the NAME of the env var a transient token arrives in. The token VALUE is
#   injected at delivery time by the operator's own tooling and is NEVER written
#   to disk under the brain. If you are about to paste a token here, stop: it
#   goes in the delivery run's environment (GITHUB_TOKEN=...), not in this file.
#
# Per-source override: any source in ../neuron/sources.yaml may set `auth:` (and
# `protocol:`) in its `delivery:` block to override the defaults below for that
# one source. Omitted => the default here applies.

# --- default auth mode (per-source `auth:` overrides) ----------------------
# public             keyless HTTPS clone — no credential at all (DEFAULT, preferred).
# operator-delivered the git adapter does NOT clone; the operator's own tooling has
#                    already written the tree into brain_ro/<name> out-of-band. The
#                    adapter only asserts the tree is present, then ingest reads it.
# transient-cred     a SHORT-LIVED credential is injected at delivery time (an HTTPS
#                    token in $GITHUB_TOKEN_ENV, or a forwarded SSH agent) — used for
#                    the single clone/fetch and DISCARDED. Never persisted, never in
#                    .git/config. This is the only in-distro path to a private repo.
GITHUB_DEFAULT_AUTH=public

# --- default protocol (per-source `protocol:` overrides) -------------------
# https | ssh. The source URL is authoritative; set this only to coerce a github.com
# URL to the other form (https<->ssh) without editing every source line. transient-cred
# pairs a token with https and a forwarded agent with ssh.
GITHUB_DEFAULT_PROTOCOL=https

# --- transient credential contract (transient-cred mode only) --------------
# GITHUB_TOKEN_ENV  the NAME of the env var that WILL hold the transient HTTPS token at
#                   delivery time. The adapter reads os.environ[this] and injects it as an
#                   Authorization header (git -c http.extraHeader=...) so it never touches
#                   the remote URL or .git/config. The value is supplied by the operator on
#                   the delivery run ONLY (e.g. `GITHUB_TOKEN=ghp_... neuron_deliver.sh`).
# GITHUB_SSH_USER   the ssh login user for ssh-form remotes (github.com uses `git`).
# GITHUB_KNOWN_HOSTS  container path to the pinned host keys (mounted from ./github),
#                   used to verify the SERVER on ssh delivery — not a client credential.
GITHUB_TOKEN_ENV=GITHUB_TOKEN
GITHUB_SSH_USER=git
GITHUB_KNOWN_HOSTS=/etc/github/known_hosts
