# gh_auth — the in-brain credential vault (CONFIG; non-secret).
# ===========================================================================
# This is a DELIBERATE PIVOT from the "no credential is ever loaded into the brain"
# posture the earlier design took. `gh_auth/` is a QUARANTINED credential zone: SSH
# private keys and GPG keys DO live in the brain seam here, but SEALED at rest under a
# GPG store passphrase that onboarding auto-generates and keeps in the OS keystore
# (never in the brain). The rest of the "brain holds nothing irreplaceable" stance is
# unchanged — this one folder is the exception, and it is opt-in (GH_AUTH_ENABLE).
#
# THIS FILE holds only NON-SECRET config. The passphrase is in the OS keystore; the
# keys are in the sealed store. Never paste a key or a passphrase here.
#
# Managed by `system/brain_sbin/gh_auth.py` (host-side admin tool). All MUTATING ops (init /
# import / reset-password / recreate) run HOST-SIDE because the seam is admin-RW /
# brain-RO; the brain only DECRYPTS at delivery time with the passphrase forwarded
# transiently for that one run (same shape as GITHUB_TOKEN in ../github.env).

# --- master switch ---------------------------------------------------------
# off  the vault is inert; git delivery uses only public / operator-delivered /
#      transient-token paths (../README.md). No key material is consulted.
# on   transient-cred SSH delivery may draw a key from the sealed vault, and git
#      signing may use a vault GPG key (see the advisory below).
GH_AUTH_ENABLE=off

# --- store locations (container paths; the seam mounts ./github at /etc/github) ----
GH_AUTH_GPG_STORE=/etc/github/gh_auth/gpg_store        # GNUPGHOME (imported GPG keys)
GH_AUTH_SSH_SEALED=/etc/github/gh_auth/ssh_keylist.gpg  # sealed SSH keylist (AES256)

# --- transient passphrase contract (delivery-time decrypt) -----------------
# GH_AUTH_PASSPHRASE_ENV  the NAME of the env var that carries the store passphrase into
#                         the ONE delivery run (the value comes from the OS keystore via
#                         run-as tooling; it is NEVER written to disk under the brain and
#                         is not this file). Unset => the vault cannot be unsealed.
GH_AUTH_PASSPHRASE_ENV=GH_AUTH_PASSPHRASE

# --- git signing (GPG keys wired to git) -----------------------------------
# GH_AUTH_SIGNING           off | on  — sign commits/tags with a vault GPG key.
# GH_AUTH_SIGNING_KEY       fingerprint of the vault GPG key to sign with (blank = default).
#
# !! NOT RECOMMENDED: signing/auth keys that carry WRITE access to a remote. !!
# The ingest pipeline clones READ-ONLY and never needs to sign or push. A write-capable
# key in the vault turns a read-only knowledge sink into a write path back to your repos —
# a materially larger blast radius. We SHIP the capability but do not choose it for you:
# prefer read-only deploy keys / fine-grained read-only tokens. If you enable signing with
# a write-capable key, that is a deliberate deployer decision, made with eyes open.
GH_AUTH_SIGNING=off
GH_AUTH_SIGNING_KEY=
