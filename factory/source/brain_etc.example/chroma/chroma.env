# Chroma server configuration - the vector store's own tuning knobs.
# ===========================================================================
# Admin-editable source of truth, exposed via the config-exposure seam as
# brain_etc/chroma/chroma.env. Loaded by the chroma container at start (compose
# env_file); a CHANGE requires a container recreate. This mirrors ollama.env:
# it is a PASSTHROUGH env_file - ANY chroma server environment variable you add
# here is handed to the container, so the WHOLE chroma config is yours to manage.
#
# NOT here (by design):
#   * CHROMA_TOKEN and the auth provider/credentials - those are STACK plumbing,
#     injected by Compose from brain.env's CHROMA_TOKEN. Do not set authn here.
#   * the published bind/port/TLS - that is gateway POSTURE (brain.env), because
#     chroma itself is sealed on brain_net and only the gateway is published.
#
# Below: the commonly-tuned knobs, documented. Uncomment + set what you need;
# anything left commented uses chroma's own default. Values are version-current
# for the :latest image - check the chroma docs if a knob is ignored.

# --- telemetry -------------------------------------------------------------
# Chroma phones home usage telemetry by default. A sealed brain turns it off.
ANONYMIZED_TELEMETRY=FALSE

# --- persistence -----------------------------------------------------------
# The store is a bind mount at /data (see compose). These are chroma's own
# persistence switches; the defaults already persist to /data.
# IS_PERSISTENT=TRUE
# PERSIST_DIRECTORY=/data

# --- CORS (browser clients) ------------------------------------------------
# JSON array of allowed origins for browser-based chroma clients. Empty by
# default (server-to-server via the gateway needs none).
# CHROMA_SERVER_CORS_ALLOW_ORIGINS=["*"]

# --- limits / performance --------------------------------------------------
# Max embeddings per add/update batch the server accepts.
# CHROMA_SERVER_NOFILE=65535
# Segment cache policy + soft memory ceiling for the in-memory index cache.
# CHROMA_SEGMENT_CACHE_POLICY=LRU
# CHROMA_MEMORY_LIMIT_BYTES=0

# --- observability (OpenTelemetry) -----------------------------------------
# Point chroma's traces/metrics at a collector. Off unless you run one.
# CHROMA_OTEL_COLLECTION_ENDPOINT=
# CHROMA_OTEL_SERVICE_NAME=chroma
# CHROMA_OTEL_GRANULARITY=all
