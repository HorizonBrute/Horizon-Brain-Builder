# Ollama server configuration - the sealed model server's tuning knobs.
# ---------------------------------------------------------------------------------
# Admin-editable source of truth, exposed via the config-exposure seam as
# brain_etc/ollama/ollama.env. Loaded by the container at start (compose env_file);
# CHANGE requires a container recreate. Ollama has NO config file - these OLLAMA_*
# env vars ARE its config (ADR 0009). This is a PASSTHROUGH env_file: ANY OLLAMA_*
# variable you add here is handed to the server, so the WHOLE ollama config is yours.
#
# Do NOT set OLLAMA_HOST here: it stays the in-container default 0.0.0.0:11434, which
# is safe because the container is sealed on brain_net with no host port (exposure is
# the gateway's job - OLLAMA_EXPOSE in brain.env, never a raw ollama bind).

# === Active knobs ================================================================

# How long a model stays resident in RAM after its last use. Longer = the embed model
# stays warm across an ingest run (no cold reload per batch); shorter = frees RAM sooner.
OLLAMA_KEEP_ALIVE=15m

# Concurrent requests served per loaded model.
OLLAMA_NUM_PARALLEL=1

# Max distinct models kept loaded at once (0 = auto, by available memory).
OLLAMA_MAX_LOADED_MODELS=0

# Request queue depth before the server sheds load (503).
OLLAMA_MAX_QUEUE=512

# === Further knobs (uncomment to use; default shown or noted) =====================

# Verbose server logging (troubleshooting). Off by default.
# OLLAMA_DEBUG=false

# How long the server waits for a model to load before erroring.
# OLLAMA_LOAD_TIMEOUT=5m

# Flash-attention (lower memory / faster attention on supported models).
# OLLAMA_FLASH_ATTENTION=false

# KV-cache quantization to shrink context memory (f16 | q8_0 | q4_0). f16 = default.
# OLLAMA_KV_CACHE_TYPE=f16

# Keep every requested model loaded and spread work across GPUs (multi-GPU hosts).
# OLLAMA_SCHED_SPREAD=false

# Do NOT prune unused model layers on start (keeps the blob cache intact).
# OLLAMA_NOPRUNE=false

# Extra VRAM (bytes) to reserve per GPU as overhead headroom.
# OLLAMA_GPU_OVERHEAD=0

# CORS allow-list for browser clients hitting ollama directly (server-to-server
# via the gateway needs none). Comma-separated origins.
# OLLAMA_ORIGINS=
