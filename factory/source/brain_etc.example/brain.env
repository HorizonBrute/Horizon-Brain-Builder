############################################################################
#  BRAIN CONTROL PANEL   —   <brain_root>/brain_etc/brain.env
#  ------------------------------------------------------------------------
#  The ONE place you configure this brain. Read it top-to-bottom like a story.
#
#  ===  CONFIGURATION FLOW  (what a fresh install expects of you)  ==========
#
#  STEP 1 — BASE CONFIG (§1–2 below)
#     Install sets sane defaults for every service. Generally untouched unless
#     you're doing advanced / off-box wiring.
#
#  STEP 2 — SECURE ACCESS (create the tokens your neurons will name)
#     Gateway auth tokens must EXIST before a neuron can reference one. They live
#     in the gateway token map (brain_etc/gateway/*_tokens.map); create/add one
#     with system/brain_sbin/gateway_tokens.py, then reference it BY NAME from a
#     neuron (gateway_token:). Default security posture:
#         INPUT neuron  → a WRITE token into the vector DB
#         ACTION neuron → a READ-ONLY token from the vector DB
#     (You may also add tokens for external → action-neuron callers, and, only if
#      you publish a backend to the LAN, external → chroma / ollama.)
#
#  STEP 3 — YOUR NEURONS (the ===NEURONS=== YAML zone below)
#     Define your bundles, neurons, and their SOURCES. Ship-minimum = 1 bundle
#     with 2 neurons (one input, one action). Two directories back a neuron:
#         impulses/<bundle>/<neuron>/   YOUR code — input providers AND action apps
#                                       (split by OWNERSHIP: everything you author).
#                                       Staged examples:
#                                         input_neuron_example/doc_provider_script.py
#                                            (reads knowledge/brain_ro/example_input_files/docs
#                                             — 3 sample docs staged)
#                                         input_neuron_example/img_provider_script.py
#                                            (reads .../imgs — 3 imgs staged)
#                                         action_neuron_example/query.py
#         neurons/<bundle>/<neuron>/    BRAIN-managed runtime for the neuron (harness,
#                                       deployed resources). You do not hand-edit here.
#
#  ===  APPLYING YOUR CHANGES  ==============================================
#  TO APPLY ANY EDIT IN THIS FILE: re-run the single re-apply tool. It regenerates
#  all backend config from brain.env, force-recreates every service (chroma, ollama,
#  gateway, fail2ban), AND reconciles the host firewall to the LAN surfaces you expose
#  here — opening/closing ports to match your PUBLISH_TO_LAN gates. Run it from an
#  Administrator console so the firewall step can apply (non-elevated still reapplies
#  the stack, but leaves the firewall untouched and says so):
#      python system/brain_sbin/reapply_brain_configs.py --brain <brain>
#
#  ---------------------------------------------------------------------------
#  DESIGN STANCE: the DEFAULT + intended path is the SECURE INTERNAL one — the
#  brain's own chroma/ollama, reached through the gateway, everything configured
#  here. But nothing paints you into a corner: any neuron may point at an external
#  chroma / ollama / (future) OpenAI-API endpoint — and its traffic STILL flows
#  through the gateway, so it is always monitored. The gateway is the ONLY service
#  a neuron cannot function without; chroma and ollama are optional, replaceable
#  backends. A platform for flexibly deploying agentic workloads securely.
#
#  TWO ZONES, split by the ===NEURONS=== marker:
#     • ABOVE = flat KEY=VALUE service panel → rendered to ~/docker/.env for compose.
#     • BELOW = nested YAML neuron definitions → read by the neuron tooling.
#  Author both by hand; the tooling splits at the marker. Never mix formats across it.
############################################################################


# ==========================================================================
# 1.  MASTER CONTROL
# ==========================================================================

# --- identity -------------------------------------------------------------
COMPOSE_PROJECT_NAME=__BRAIN_NAME__     # docker project name = brain name (literal)
BRAIN_NAME=__BRAIN_NAME__               # this brain's name (literal, never ${BRAIN_NAME})
DEFAULT_BUNDLE=example_neuron_bundle     # the zone's default bundle (index 0, the neuron_net); blank ⇒ brain name

# --- network posture (ONE switch sets the brain's whole stance) ----------
#   workstation = every surface is loopback-only (127.0.0.1); nothing faces the LAN.
#   server      = surfaces become ELIGIBLE for the LAN, then each opts in via PUBLISH_TO_LAN.
BRAIN_POSTURE=server

# --- gateway external exposure (master kill-switch for ALL host ports) ----
# The gateway ALWAYS runs — it is the internal bridge every neuron uses to reach its
# backends (and the monitoring chokepoint for ALL neuron traffic). This knob is NOT
# "run the gateway"; it is "does the gateway bind ANY host port (not even 127.0.0.1)".
# OFF ⇒ a fully sealed brain. ON ⇒ host publishing allowed, shaped by BRAIN_POSTURE +
# the per-service / per-neuron PUBLISH_TO_LAN gates.
EXTERNAL_GATEWAY_ENABLE=on

# --- which BUILT-IN backends run ------------------------------------------
# The brain's OWN chroma/ollama. OPTIONAL: a brain whose neurons all point at external
# endpoints can turn them off — NOT brain-breaking. Default ON (the secure internal path).
CHROMA_ENABLE=on
OLLAMA_ENABLE=on
FAIL2BAN_ENABLE=on                        # brute-force guard on the gateway (meaningful only when exposed)

# --- which built-in backends reach the LAN (only when BRAIN_POSTURE=server) ---
CHROMA_PUBLISH_TO_LAN=NO
OLLAMA_PUBLISH_TO_LAN=NO

# --- image versions -------------------------------------------------------
CHROMA_VERSION=latest
OLLAMA_VERSION=latest
FAIL2BAN_VERSION=latest

# --- docker plumbing (DERIVED — do not hand-edit) -------------------------
# Kept in lockstep with the knobs above; a deploy-time check fails closed on drift
# (prevents the NOTE 001-19 port-loss loop). Base stack + one publish overlay per surface:
#   compose.yaml                       the whole stack (backends + gateway skeleton + neurons + nets)
#   compose.chroma-gateway.yaml        adds the gateway's :8000 host publish for chroma
#   compose.ollama-gateway.yaml        adds the gateway's :11434 host publish for ollama
#   compose.action-neuron-gateway.yaml publishes ANY type:action neuron that declares exposed ports
COMPOSE_PROFILES=gateway,ollama,fail2ban
COMPOSE_FILE=compose.yaml:compose.chroma-gateway.yaml:compose.ollama-gateway.yaml:compose.action-neuron-gateway.yaml


# ==========================================================================
# 2.  SERVICE KNOBS   (the brain's BUILT-IN services)
# ==========================================================================
# PARITY NOTE: a NEURON can override these per-neuron for its OWN backends/surface —
# tls, authz, inspect, and its published port(s) — in its neuron block below. The
# values here are the brain-wide DEFAULT the built-in services use.

# --- GATEWAY  (the nginx reverse proxy: the brain's single front door) ----
GW_BIND_ADDRESS=0.0.0.0                    # the one address all published listeners bind
CHROMA_MASTER_TOKEN_FOR_GW=                # master gateway↔backend secret; GENERATED at deploy, leave blank
GATEWAY_INSPECT_LOG=unified                # unified | split — how captured traffic is logged

# --- CHROMA  (built-in vector store) -------------------------------------
CHROMA_PORT=8000                           # EXTERNAL published port at the gateway (backend internal port is fixed)
CHROMA_GW_TLS=enforced                     # enforced | off
CHROMA_GW_AUTHZ=token-role                 # token-role | token | off
CHROMA_INTERNAL_INSPECT=request            # off | request | request+response
CHROMA_EXTERNAL_INSPECT=request

# --- OLLAMA  (built-in model server) -------------------------------------
OLLAMA_PORT=11434
OLLAMA_GW_TLS=enforced
OLLAMA_GW_AUTHZ=token-role
OLLAMA_INTERNAL_INSPECT=request
OLLAMA_EXTERNAL_INSPECT=request

# --- FAIL2BAN  (brute-force guard; sees real client IPs under mirrored net) ---
# (enable/version in §1; policy lives on the seam at brain_etc/fail2ban/.)

# --- Brain-Internal Network segmentation — ONLY modify if there is IP overlap in your environment ---
NEURON_NET_SUBNET=192.168.255.0/24
GATEWAY_NEURON_IP=192.168.255.2
NEURON_NET_DYNRANGE=192.168.255.128/25     # NOTE: must sit INSIDE NEURON_NET_SUBNET. Your note said
                                           # 192.168.254.128/25 (outside .255); set to .255.128/25 to keep
                                           # it valid. Flip the subnet to .254.0/24 if you meant .254 literally.
BRAIN_NET_SUBNET=172.16.254.0/23
# To maximize no-overlap, a spicy deployer could experiment with APIPA space (169.254.0.0/16).

# --- centralized log seam -------------------------------------------------
# Logs write in-distro at /home/<brain>/logs/<source>-<YYYYMMDD>.log and surface host-side
# READ-ONLY at <brain_root>/system/brain_logs/live/ (the "logs door").
BRAIN_ENABLE_LOGGING=on
BRAIN_LOG_SOURCES=gateway,wsl,chroma,ollama
BRAIN_LOG_ROTATE_WHEN=daily+size
BRAIN_LOG_ROTATE_SIZE=100M
BRAIN_LOG_RETENTION_DAYS=30
BRAIN_LOG_DATESTAMP=%Y%m%d
BRAIN_LOG_WSL_FILTER=
BRAIN_DOCKER_LOG_MAX_SIZE=50m
BRAIN_DOCKER_LOG_MAX_FILE=3


# ==========================================================================
#  SEAM MAP — where each service's DEEP config lives, and how to apply an edit
# ==========================================================================
# The knobs above are the panel; the files below are the transparently-exposed
# detail behind them. Edit a seam file, then run the apply tooling AS THE BRAIN:
#   python system/brain_sbin/run_as_brain.py --wsl -- \
#          python system/brain_sbin/brain_truths.py --brain <brain> apply
# then recreate the affected container. Service-specific regen tools noted per row.
# (Exact per-seam apply commands are being confirmed as we build this table.)
#
#   SERVICE / AREA   SEAM LOCATION (brain_etc/)      APPLY AFTER EDITING
#   ---------------  -----------------------------   ----------------------------------
#   Chroma           chroma/chroma.env               brain_truths apply → recreate chroma
#   Ollama (tuning)  ollama/ollama.env               brain_truths apply → recreate ollama
#   Ollama (models)  ollama/models                   brain_truths apply → model pull
#   Gateway (nginx)  gateway/ (ratelimit.conf, …)    gateway_config.py regen → recreate gateway
#   Gateway (tokens) gateway/*_tokens.map            gateway_tokens.py → recreate gateway
#   Fail2ban         fail2ban/{jail,filter,action}.d brain_truths apply → recreate fail2ban
#   GitHub delivery  github/ (github.env, known_hosts) brain_truths apply
#   TLS certs        tls/  (→ gateway_out)            regen certs → recreate gateway
#   Firewall         (derived from brain.env)         gateway_port.py apply
#   WSL / mirrored   wsl/ (.wslconfig symlink)        write .wslconfig → cold-boot the brain VM
#   Ingest schedule  (schedules: in this file)        neuron_schedule.py
#   Docker / .env    docker/ (compose.*, .env)        rendered from brain.env by deploy/reapply


# ==========================================================================
# ===NEURONS===   (everything below is YAML — nested; tooling reads this zone)
# ==========================================================================
# A BUNDLE groups neurons over one doc collection. Each NEURON is one pipeline:
#   type: input   consumes one or MORE sources → WRITES the bundle's collection
#   type: action  serves an app (e.g. query.py) that READS it
#
# BACKENDS default to `internal` (the brain's own service via the gateway — the secure
# default). Set per BUNDLE (default for its neurons) and override per NEURON. `internal`
# and an explicit off-box URL BOTH route through the gateway (always monitored).
#
# TOKENS are referenced BY NAME from the gateway token map (Step 2). No secret lives
# here; nothing is auto-minted. INPUT = write token; ACTION = read-only token (you can
# break this — unwise, not blocked).
#
# Consumption types: on-disk | script | git. git protocol: ssh | none(=public); https
# UNSUPPORTED. script + app paths resolve under impulses/<bundle>/<neuron>/ (your code);
# neurons/<bundle>/<neuron>/ is the brain-managed runtime. Schedules map name → cron (below).

schedules:
  15-minutes: "*/15 * * * *"
  hourly:     "0 * * * *"
  daily:      "0 3 * * *"
  weekly:     "0 3 * * 0"

# The SHIPPED DEFAULT bundle — a working input+action pair for a first-run smoke test.
neuron_bundles:
  - name: example_neuron_bundle
    default_collection: example_docs
    description: Shipped example — one input neuron (docs + images) and two action neurons (a
                 one-shot CLI + a served :8443 query API), a first-run smoke test.
    backends:
      chroma:    { endpoint: internal }         # internal | https://host:port (off-box allowed)
      inference: { provider: ollama, endpoint: internal }
      #          { provider: openai, endpoint: https://api.openai.com/v1, api_key_gpg_id: <future GPG key id> }
    neurons:

      - name: input_neuron_example
        type: input
        gateway_token: example_bundle_writer     # WRITE token (named in the gateway token map)
        embed_model: nomic-embed-text
        schedule: hourly
        sources:
          - name: docs
            consumption: script
            script: doc_provider_script.py        # impulses/example_neuron_bundle/input_neuron_example/
            ingest_scope: { include: ["*.md", "*.txt"] }
          - name: images
            consumption: script
            script: img_provider_script.py        # impulses/example_neuron_bundle/input_neuron_example/
            ingest_scope: { include: ["*.png", "*.jpg", "*.jpeg"] }

      # An action neuron's `service_type` picks ONE compose shape (ADR-0020 Q1). The shipped
      # example ships BOTH so a first-run demonstrates each pattern:
      #   on-demand → a one-shot (restart:"no"), driven by `docker compose run`; NOT published.
      #   daemon    → a long-running HTTP server; the gateway routes :8443 to it (published).
      - name: action_neuron_cli
        type: action
        gateway_token: example_bundle_reader      # READ-ONLY token
        synth_model: qwen2.5:1.5b
        app:
          dir:                                    # empty ⇒ impulses/example_neuron_bundle/action_neuron_cli/
          executable: query.py
          service_type: on-demand                 # one-shot: `docker compose run --rm action_neuron_cli --query "…"`
        # NO publish_to_lan_ports — a one-shot has no listener for the gateway to route to.
        # per-neuron PARITY overrides (else inherit §2 defaults):
        # tls: enforced           # enforced | off
        # authz: token            # token-role | token | off
        # inspect: request+response

      - name: action_neuron_api
        type: action
        gateway_token: example_bundle_reader      # READ-ONLY token (same read scope as the CLI)
        synth_model: qwen2.5:1.5b
        app:
          dir:                                    # empty ⇒ impulses/example_neuron_bundle/action_neuron_api/
          executable: query.py
          service_type: daemon                    # served: --serve on an internal port; gateway fronts it
        publish_to_lan: yes
        publish_to_lan_ports: [8443]              # the gateway publishes :8443 and path-routes to this neuron
