# Horizon AIOS — per-brain Chroma stack configuration (TEMPLATE)
# ---------------------------------------------------------------
# This is the committed template. The admin onboarding script (`../onboard.py`)
# reads it, substitutes brain-specific values, and writes the live `.env` next
# to it. `docker compose` auto-loads `.env` from this directory.
#
# Treat `.env` as the 12-factor carrier for this brain's runtime config rather
# than mutating per-user OS environment variables (which don't travel with the
# deployable folder and are awkward to set for a non-interactive brain account).

# Compose project name → namespaces every resource. Set to the brain name.
COMPOSE_PROJECT_NAME=__BRAIN_NAME__

# Brain identity, consumed by compose for container/volume/network names.
BRAIN_NAME=__BRAIN_NAME__

# Pinned image version. Bump deliberately; re-test retrieval after a major bump.
CHROMA_VERSION=1.5.0

# Host port published on 127.0.0.1. Give each brain its own port so multiple
# brains' Chroma instances coexist (e.g. 8000, 8001, 8002, ...).
CHROMA_PORT=8000
