# Horizon AIOS — brain Chroma+gateway stack config (TEMPLATE)
# -----------------------------------------------------------
# Onboarding reads this template, substitutes per-brain values, and writes the live
# `.env` next to the compose file in the distro (~/docker/.env). compose auto-loads it.

# Compose project name + brain identity → namespaces every resource.
COMPOSE_PROJECT_NAME=__BRAIN_NAME__
BRAIN_NAME=__BRAIN_NAME__

# Pinned Chroma image. Bump deliberately; re-test retrieval after a major bump.
CHROMA_VERSION=1.5.0

# Pinned Ollama image (the sealed embedding/LLM model server). Bump deliberately.
OLLAMA_VERSION=0.31.1

# Pinned fail2ban image (gateway intrusion banning, ADR 0012). Bump deliberately.
FAIL2BAN_VERSION=1.1.0

# --- Gateway (the ONE published surface) ------------------------------------
# The static token the gateway injects upstream AND Chroma now requires. Generate
# with `openssl rand -hex 32`. The only holders are the gateway + neuron container.
# Canonical name across stage4_brain.sh render + gateway_config.py (compose sources
# the container-internal CHROMA_TOKEN alias from this one secret).
CHROMA_MASTER_TOKEN_FOR_GW=__GENERATED_AT_ONBOARD__

# --- Gateway published ports (client-facing — the ONLY port knobs) ----------
# Both the Chroma and the Ollama gateway run inside the ONE nginx. These are the HOST
# ports clients connect to; nginx's INTERNAL listen ports (Chroma 8000, Ollama 11434)
# are fixed behind the docker port mapping, so each gateway is a single number here.
# BIND = which host interface: 127.0.0.1 (loopback, no firewall change) or 0.0.0.0
# (host NIC(s) — LAN/workstation-reachable; pair with a Windows Defender inbound rule).
# TLS is always on for Chroma; for Ollama it follows OLLAMA_GW_TLS (below).
#
# Chroma read/write gateway (published when GATEWAY_ENABLE=on). 8000 = the standard
# Chroma port the gateway takes over, so existing clients/plugins work unmodified.
GATEWAY_BIND=127.0.0.1
GATEWAY_PORT=8000
# Ollama gateway (published only when OLLAMA_EXPOSE=on — see the exposure block below).
# NOTE: default is 11435, NOT Ollama's standard 11434 — a host/dev machine often runs its
# OWN Ollama on 11434, and publishing the gateway there collides (`address already in use`
# → the up fails). 11435 sidesteps that; clients just point at :11435. Use 11434 only on a
# box with no host Ollama.
OLLAMA_GW_BIND=127.0.0.1
OLLAMA_GW_PORT=11435

# --- Brain composition profiles (ADR 0011) ----------------------------------
# Which optional services actually run. chroma (+ the neuron writer) are always on;
# the gateway, the ollama model server, and the fail2ban guard are profile-gated.
# COMPOSE_PROFILES is what Compose reads; the *_ENABLE knobs are the human-facing dials
# the enable-tooling / onboarding translate into it. Default = a full exposed brain.
#   Exposed (default) : gateway,ollama,fail2ban   Self-contained : ollama   Minimal : (empty)
COMPOSE_PROFILES=gateway,ollama,fail2ban
GATEWAY_ENABLE=on
OLLAMA_ENABLE=on

# --- Gateway intrusion banning (fail2ban, ADR 0012) -------------------------
# Bans a source IP that trips too many gateway denials (repeated 403 = token probing) in
# a window, then self-heals. Requires the gateway (it shares its network namespace); leave
# it OUT when GATEWAY_ENABLE=off. on => `fail2ban` in COMPOSE_PROFILES (the sidecar runs);
# off => omitted (no sidecar, zero overhead). The ban POLICY — bantime (self-heal),
# findtime + maxretry (failures per window) — lives on the seam: brain_etc/fail2ban/jail.d/.
# A read-only view of the CURRENTLY banned IPs is written to ~/docker/fail2ban/state/current_bans.txt.
# NOTE: banning needs the gateway to see REAL client IPs — on WSL2 that means mirrored
# networking (.wslconfig networkingMode=mirrored); under NAT the source IP is masked (ADR 0012 §5).
FAIL2BAN_ENABLE=on
# fail2ban server log verbosity: CRITICAL|ERROR|WARNING|NOTICE|INFO|DEBUG.
FAIL2BAN_LOG_LEVEL=INFO
# How long ban history is retained in the sqlite db before purge (s/m/h/d, e.g. 1d, 7d).
FAIL2BAN_DB_PURGE_AGE=1d

# --- Ollama gateway exposure (ADR 0009) -------------------------------------
# Whether a PRESENT ollama (OLLAMA_ENABLE=on) is reachable OFF-BOX through the gateway
# on :11434. Distinct from OLLAMA_ENABLE (in-stack-or-not). OFF = sealed on brain_net
# (the safe default). When on, layer the exposure override:
#   docker compose -f compose.yaml -f compose.ollama-gateway.yaml up -d
OLLAMA_EXPOSE=off
# TLS on the 11434 listener: off (plain http) | enforced (https, reuses the gateway cert).
OLLAMA_GW_TLS=enforced
# Admission model: open (no token) | token (any valid token) | token-role (use vs admin).
# token-role is the safe default; management endpoints are ALWAYS admin-only regardless.
OLLAMA_GW_AUTHZ=token-role
# (The Ollama gateway's host bind + port — OLLAMA_GW_BIND / OLLAMA_GW_PORT — are set in
#  the "Gateway published ports" block above, alongside the Chroma gateway's.)

# --- neurons (scaffold; set when the pipeline image exists) ------------------
# NEURON_IMAGE=${BRAIN_NAME}/neurons:latest
