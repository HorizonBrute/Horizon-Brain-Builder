# Ollama server configuration — the sealed model server's tuning knobs.
# ---------------------------------------------------------------------------------
# Admin-editable source of truth, exposed via the config-exposure seam as
# brain_etc/ollama/ollama.env. Loaded by the container at start (compose env_file);
# CHANGE requires a container recreate (`brain_service ollama restart` recreates via
# compose). Ollama has NO config file — these OLLAMA_* env vars ARE its config (ADR 0009).
#
# Do NOT set OLLAMA_HOST here: it stays the in-container default 0.0.0.0:11434, which
# is safe because the container is sealed on brain_net with no host port.

# How long a model stays resident in RAM after its last use. Longer = the embed model
# stays warm across an ingest run (no cold reload per batch); shorter = frees RAM sooner.
OLLAMA_KEEP_ALIVE=15m

# Concurrent requests served per loaded model.
OLLAMA_NUM_PARALLEL=1

# Max distinct models kept loaded at once (0 = auto, by available memory).
OLLAMA_MAX_LOADED_MODELS=0

# Request queue depth before the server sheds load (503).
OLLAMA_MAX_QUEUE=512
